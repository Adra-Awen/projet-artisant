doctype html
html
  head
    meta(charset='utf-8')
    meta(name='viewport', content='width=device-width, initial-scale=1')
    meta(name='description', content='Trouvez les meilleurs artisans de la région Auvergne-Rhône-Alpes pour tous vos projets de rénovation, construction et décoration. Notre annuaire en ligne vous permet de rechercher facilement des professionnels qualifiés par catégorie et localisation.')
    meta(name='keywords', content='artisans, annuaire, Auvergne-Rhône-Alpes, services, alimentation, rénovation, construction, professionnels qualifiés')
    meta(name='author', content='Nolwenn Bauvais')
    title Trouve ton artisan - #{title}
  
    link(rel='icon', type='image/png', href='/images/favicon.png')
    link(rel='stylesheet', href='/stylesheets/style.css')
    link(rel='stylesheet', href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css')
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")
  body
    nav.custom-navbar
      .container
        .navbar-content
          a.navbar-brand-link(href="/")
            .logo-area
              img.logo(src="/images/Logo.png" alt="Logo de la région Auvergne-Rhône-Alpes" class="region-logo")
          button.menu-toggle(type="button")
            i.bi.bi-list
          .nav-controls
            .search-wrapper
              form(action="/entreprises/search", method="GET")
                .input-group
                  input.form-control.search-input(type="text", name="q", placeholder="Rechercher un artisan...")
                  button.btn.search-btn(type="submit")
                    i.bi.bi-search 
            ul.nav-links
              if categories
                each category in categories
                  li
                    a(href=`/categories/${category.slug}`, class=(title === category.nom ? 'active' : '')) #{category.nom}
    block content
    include footer

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js')
    script.
      const toggle = document.querySelector('.menu-toggle');
      const nav = document.querySelector('.nav-controls');

      toggle.addEventListener('click', () => {
        nav.classList.toggle('open');
      });

