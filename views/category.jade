extends layout

block content
  h1.mt-4 #{category.nom}
  hr
  .row
    if entreprises && entreprises.length > 0
      each ent in entreprises
        .col-md-3
          .card.mb-4.shadow-sm
            .card-body
              h5.card-title #{ent.nom}
              h6.card-subtitle.mb-2.text-muted #{ent.specialiteNom || 'Artisan'}
              p.card-text #{ent.ville}
              p.text-warning 
                - for (var i = 0; i < Math.round(ent.note); i++)
                  | ★
              a.btn.btn-outline-primary.w-100(href=`/entreprises/${ent.id_entreprise}`) Découvrir
    else
      p Aucun artisan dans cette catégorie pour le moment.